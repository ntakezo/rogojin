package states

import (
	"context"
	"io"
	"net/http"

	"github.com/ntakezo/rogojin/workflows"
)

// Fetch retrieves the input URL and stores the body for the next state. It is
// the graph's initial state.
func (c *Context) Fetch(ctx context.Context) (*workflows.State, error) {
{{- if .Proxy}}
	client, err := c.client(ctx)
	if err != nil {
		return nil, err
	}
{{- else}}
	client := http.DefaultClient
{{- end}}
	req, err := http.NewRequestWithContext(ctx, http.MethodGet, c.input.URL, nil)
	if err != nil {
		return nil, err
	}
	res, err := client.Do(req)
	if err != nil {
		return nil, err
	}
	defer res.Body.Close()
	body, err := io.ReadAll(res.Body)
	if err != nil {
		return nil, err
	}
	c.r.body = string(body)
	return workflows.Next(process), nil
}
